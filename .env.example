# LangSmith Configuration
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
# Alinhe com o setup do LangSmith (Settings → Configure environment / projeto de traces)
LANGSMITH_PROJECT=prompt-optimization-challenge-resolved

# Opcional: apenas se usar Anthropic CLI/SDK fora deste projeto; o boilerplate avalia com OpenAI ou Gemini.

ANTHROPIC_API_KEY=

# Para descobrir seu username: publique qualquer prompt no LangSmith Hub, depois abra-o e clique no ícone de cadeado (🔒) para ver seu username.
USERNAME_LANGSMITH_HUB=

# OpenAI Configuration
OPENAI_API_KEY=

# Google Gemini Configuration
GOOGLE_API_KEY=

# LLM Configuration
LLM_PROVIDER=google
LLM_MODEL=gemini-2.5-flash
EVAL_MODEL=gemini-2.5-flash

#LLM_PROVIDER=openai
#LLM_MODEL=gpt-4o-mini
#EVAL_MODEL=gpt-4o